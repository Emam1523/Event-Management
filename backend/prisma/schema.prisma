generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  phone           String?
  password        String?
  googleId        String?
  facebookId      String?
  avatar          String?
  role            String         @default("user")
  emailVerified   Boolean        @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  events          Event[]        @relation("OrganizerEvents")
  bookings        Booking[]
  notifications   Notification[]
  reviews         Review[]
  appReviews      AppReview[]
}

model Event {
  id           String       @id @default(uuid())
  title        String
  description String
  fullDescription String?
  capacity    Int?
  category    String
  date         String
  time         String
  endTime      String?
  location     String
  googleMapUrl String?
  price        Float
  image        String?
  organizerId  String
  organizer    User         @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  bookings     Booking[]
  reviews      Review[]
  tickets      TicketType[]

  @@index([category])
  @@index([location])
  @@index([category, location])
}

model TicketType {
  id          String  @id @default(uuid())
  name        String
  price       Float
  description String?
  capacity    Int     @default(100)
  sold        Int     @default(0)
  eventId     String
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType String
  quantity   Int
  totalPrice Float
  status     String   @default("confirmed")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  payment    Payment?
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount        Float
  status        String   @default("pending")
  method        String
  transactionId String?
  createdAt     DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model VerificationCode {
  id         String    @id @default(uuid())
  email      String
  purpose    String
  codeHash   String
  metadata   Json?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose, consumedAt])
  @@index([expiresAt])
}

model Location {
  id   String @id @default(uuid())
  name String @unique
}

model AppReview {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
